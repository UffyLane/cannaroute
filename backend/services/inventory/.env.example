# Inventory Service — Environment Variables

NODE_ENV=development
PORT=3004

DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_postgres_password
DB_NAME=cannaroute_dev

JWT_SECRET=same_value_as_auth_service

CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# AWS S3 — product images
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=cannaroute-products

# Metrc API — seed-to-sale reporting
METRC_BASE_URL=https://api.metrc.com
METRC_SOFTWARE_API_KEY=...
# Dispensary-specific Metrc keys are stored encrypted in the dispensaries table

# Service URLs
COMPLIANCE_SERVICE_URL=http://localhost:3005
