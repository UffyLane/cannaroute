# Notification Service — Environment Variables

NODE_ENV=development
PORT=3007

DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_postgres_password
DB_NAME=cannaroute_dev

JWT_SECRET=same_value_as_auth_service

# Firebase FCM — push notifications
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Twilio — SMS delivery alerts + OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15005550006

# SendGrid — transactional email (Phase 2)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@cannaroute.com
