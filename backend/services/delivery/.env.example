# Delivery Service — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_postgres_password
DB_NAME=cannaroute_dev

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=same_value_as_auth_service

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ─── Redis — GPS tracking ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  (leave blank for local dev)

# ─── AWS S3 — signature + proof photos ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=cannaroute-deliveries

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Enable: Directions API, Distance Matrix API, Geocoding API
GOOGLE_MAPS_API_KEY=AIza...

# ─── Service-to-service URLs ─────────────────────────────────────────────────
ORDER_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3007
