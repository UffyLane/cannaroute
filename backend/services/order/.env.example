# Order Service — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_postgres_password
DB_NAME=cannaroute_dev

# ─── JWT (same secret as auth service — all services share for verification) ──
JWT_SECRET=same_value_as_auth_service

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ─── Service-to-service URLs ─────────────────────────────────────────────────
# In production these will be internal k8s service DNS names
DELIVERY_SERVICE_URL=http://localhost:3003
INVENTORY_SERVICE_URL=http://localhost:3004
COMPLIANCE_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3007

# ─── Redis (Phase 2 — real-time GPS relay, caching) ──────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
