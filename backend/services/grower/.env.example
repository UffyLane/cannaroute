# Grower Service — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3006

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_postgres_password
DB_NAME=cannaroute_dev

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=same_value_as_auth_service

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ─── AWS S3 — COA PDFs, farm photos, logos ───────────────────────────────────
# IAM user needs s3:PutObject + s3:GetObject on the bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=cannaroute-dev

# ─── Service-to-service URLs ─────────────────────────────────────────────────
NOTIFICATION_SERVICE_URL=http://localhost:3007

# ─── Third-party APIs ────────────────────────────────────────────────────────
# Metrc (state track-and-trace) — get sandbox key from metrc.com
METRC_API_KEY=
METRC_BASE_URL=https://sandbox-api-mi.metrc.com

# EPA pesticide verification — no key required, public API
# https://ordspub.epa.gov/ords/pesticides/f?p=APPRREG
# No env var needed — URL is hardcoded in grower.service.ts

# CRA Accela (cannabis license verification) — contact CRA for API credentials
# Stub in grower.service.ts: replace with real values when credentials are obtained
CRA_API_KEY=
CRA_BASE_URL=https://api.cra.state.gov
