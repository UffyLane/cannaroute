# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3006

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cannaroute
DB_PASSWORD=your_password
DB_NAME=cannaroute_dev
DB_SYNC=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ─── CanPay Integration ───────────────────────────────────────────────────────
# Sign up at https://canpay.com/merchant
CANPAY_API_KEY=your_canpay_api_key
CANPAY_MERCHANT_ID=your_merchant_id
CANPAY_WEBHOOK_SECRET=your_webhook_secret
CANPAY_BASE_URL=https://sandbox.canpay.com/api/v1

# ─── AeroPay Integration (alternative processor) ─────────────────────────────
AEROPAY_API_KEY=
AEROPAY_MERCHANT_UUID=
AEROPAY_BASE_URL=https://staging.aeropay.com/api

# ─── Service URLs ─────────────────────────────────────────────────────────────
ORDER_SERVICE_URL=http://localhost:3002
AUTH_SERVICE_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
