{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_SERVICE_URL": "https://cannaroute-auth.onrender.com",
        "EXPO_PUBLIC_DELIVERY_SERVICE_URL": "https://cannaroute-delivery.onrender.com",
        "EXPO_PUBLIC_ORDER_SERVICE_URL": "https://cannaroute-order.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_SERVICE_URL": "https://cannaroute-auth.onrender.com",
        "EXPO_PUBLIC_DELIVERY_SERVICE_URL": "https://cannaroute-delivery.onrender.com",
        "EXPO_PUBLIC_ORDER_SERVICE_URL": "https://cannaroute-order.onrender.com"
      }
    },
    "production": {
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_AUTH_SERVICE_URL": "https://cannaroute-auth.onrender.com",
        "EXPO_PUBLIC_DELIVERY_SERVICE_URL": "https://cannaroute-delivery.onrender.com",
        "EXPO_PUBLIC_ORDER_SERVICE_URL": "https://cannaroute-order.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
