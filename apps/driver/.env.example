# ─── Driver App ───────────────────────────────────────────────────────────────
# Local dev: copy to .env
# Production: set in EAS dashboard or eas.json "env" block under each profile
# ─────────────────────────────────────────────────────────────────────────────

# Local development
EXPO_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
EXPO_PUBLIC_ORDER_SERVICE_URL=http://localhost:3002
EXPO_PUBLIC_DELIVERY_SERVICE_URL=http://localhost:3004
EXPO_PUBLIC_SOCKET_URL=http://localhost:3002

# Production (set in EAS after domain setup + rebuild)
# EXPO_PUBLIC_AUTH_SERVICE_URL=https://api.cannaroute.com
# EXPO_PUBLIC_ORDER_SERVICE_URL=https://cannaroute-order.onrender.com
# EXPO_PUBLIC_DELIVERY_SERVICE_URL=https://cannaroute-delivery.onrender.com
# EXPO_PUBLIC_SOCKET_URL=https://cannaroute-order.onrender.com

# Maps (https://console.cloud.google.com → Maps SDK for Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
