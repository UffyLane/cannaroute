{
  "expo": {
    "name": "CannaRoute",
    "slug": "cannaroute-customer",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f4c35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cannaroute.customer",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your ID for age verification.",
        "NSPhotoLibraryUsageDescription": "Used to upload your medical card.",
        "NSLocationWhenInUseUsageDescription": "Used to find dispensaries near you and track your delivery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f4c35"
      },
      "package": "com.cannaroute.customer",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CannaRoute to use your location."
        }
      ]
    ],
    "scheme": "cannaroute",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a351bd58-e36d-42c8-8a9f-a4993e452664"
      }
    },
    "owner": "uffylane"
  }
}
