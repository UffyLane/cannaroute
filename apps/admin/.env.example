# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Local dev: copy to .env.local
# Production (Vercel): set under Settings → Environment Variables
# Custom domain: https://admin.cannaroute.com
# ─────────────────────────────────────────────────────────────────────────────

# Local development
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_ORDER_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_INVENTORY_SERVICE_URL=http://localhost:3003
NEXT_PUBLIC_DELIVERY_SERVICE_URL=http://localhost:3004
NEXT_PUBLIC_COMPLIANCE_SERVICE_URL=http://localhost:3005
NEXT_PUBLIC_GROWER_SERVICE_URL=http://localhost:3006

# Production (set these in Vercel dashboard after domain setup)
# NEXT_PUBLIC_AUTH_SERVICE_URL=https://api.cannaroute.com
# NEXT_PUBLIC_ORDER_SERVICE_URL=https://cannaroute-order.onrender.com
# NEXT_PUBLIC_INVENTORY_SERVICE_URL=https://cannaroute-inventory.onrender.com
# NEXT_PUBLIC_DELIVERY_SERVICE_URL=https://cannaroute-delivery.onrender.com
# NEXT_PUBLIC_COMPLIANCE_SERVICE_URL=https://cannaroute-compliance.onrender.com
# NEXT_PUBLIC_GROWER_SERVICE_URL=https://cannaroute-grower.onrender.com
